#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
设置界面模块
提供统一的设置管理界面，整合各个设置模块
"""

import os
import sys
import tkinter as tk
from tkinter import ttk, messagebox
import logging
from typing import Dict, Any, List, Optional

# 导入设置模块
from .gernal import GeneralSettings
from .python_manager import PythonManager
from .proxy_settings import ProxySettings
from .mirror import MirrorSettings

logger = logging.getLogger(__name__)

class SettingsWindow:
    """
    设置窗口类
    整合通用设置、Python管理、代理设置和镜像设置等多个设置面板
    """
    
    def __init__(self, parent, settings_manager, theme_manager=None):
        """
        初始化设置窗口
        
        Args:
            parent: 父窗口
            settings_manager: 设置管理器实例
            theme_manager: 主题管理器实例
        """
        self.parent = parent
        self.settings_manager = settings_manager
        self.theme_manager = theme_manager
        
        # 创建顶层窗口
        self.window = tk.Toplevel(parent)
        self.window.title("PyQuick 设置")
        self.window.geometry("800x600")
        self.window.minsize(700, 500)
        self.window.transient(parent)
        self.window.grab_set()
        
        # 居中显示
        self.center_window()
        
        # 设置图标
        try:
            if hasattr(parent, "iconphoto"):
                icon = parent.winfo_toplevel().icon
                if icon:
                    self.window.iconphoto(True, icon)
        except Exception as e:
            logger.warning(f"设置窗口图标失败: {str(e)}")
        
        # 创建设置面板
        self.settings_panels = {}
        self._create_ui()
        
        # 应用主题
        if theme_manager:
            self.apply_theme()
    
    def center_window(self):
        """将窗口居中显示"""
        self.window.update_idletasks()
        width = self.window.winfo_width()
        height = self.window.winfo_height()
        x = (self.window.winfo_screenwidth() // 2) - (width // 2)
        y = (self.window.winfo_screenheight() // 2) - (height // 2)
        self.window.geometry(f"{width}x{height}+{x}+{y}")
    
    def apply_theme(self):
        """应用当前主题到窗口"""
        if self.theme_manager:
            try:
                self.theme_manager.apply_theme(self.window)
            except Exception as e:
                logger.error(f"应用主题失败: {str(e)}")
    
    def _create_ui(self):
        """创建设置界面"""
        # 创建主框架
        main_frame = ttk.Frame(self.window, padding=(10, 5))
        main_frame.pack(fill=tk.BOTH, expand=True)
        
        # 创建选项卡控件
        notebook = ttk.Notebook(main_frame)
        notebook.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        
        # 创建通用设置面板
        self._create_general_tab(notebook)
        
        # 创建Python版本管理面板
        self._create_python_tab(notebook)
        
        # 创建镜像设置面板
        self._create_mirror_tab(notebook)
        
        # 创建代理设置面板
        self._create_proxy_tab(notebook)
        
        # 创建网络测试面板
        self._create_network_tab(notebook)
        
        # 创建底部按钮
        self._create_buttons(main_frame)
    
    def _create_general_tab(self, notebook):
        """创建通用设置选项卡"""
        try:
            general_settings = GeneralSettings(notebook, self.settings_manager, self.theme_manager)
            general_frame = general_settings.get_frame()
            notebook.add(general_frame, text="通用设置")
            self.settings_panels["general"] = general_settings
        except Exception as e:
            logger.error(f"创建通用设置面板失败: {str(e)}")
            # 创建错误提示页面
            error_frame = ttk.Frame(notebook)
            ttk.Label(error_frame, text=f"加载通用设置失败: {str(e)}").pack(padx=20, pady=20)
            notebook.add(error_frame, text="通用设置")
    
    def _create_python_tab(self, notebook):
        """创建Python版本管理选项卡"""
        try:
            python_manager = PythonManager(notebook, self.settings_manager)
            python_frame = python_manager.get_frame()
            notebook.add(python_frame, text="Python管理")
            self.settings_panels["python"] = python_manager
        except Exception as e:
            logger.error(f"创建Python管理面板失败: {str(e)}")
            # 创建错误提示页面
            error_frame = ttk.Frame(notebook)
            ttk.Label(error_frame, text=f"加载Python管理面板失败: {str(e)}").pack(padx=20, pady=20)
            notebook.add(error_frame, text="Python管理")
    
    def _create_mirror_tab(self, notebook):
        """创建镜像设置选项卡"""
        try:
            mirror_settings = MirrorSettings(self.settings_manager)
            mirror_frame = mirror_settings.create_settings_frame(notebook)
            notebook.add(mirror_frame, text="镜像设置")
            self.settings_panels["mirror"] = mirror_settings
        except Exception as e:
            logger.error(f"创建镜像设置面板失败: {str(e)}")
            # 创建错误提示页面
            error_frame = ttk.Frame(notebook)
            ttk.Label(error_frame, text=f"加载镜像设置面板失败: {str(e)}").pack(padx=20, pady=20)
            notebook.add(error_frame, text="镜像设置")
    
    def _create_proxy_tab(self, notebook):
        """创建代理设置选项卡"""
        try:
            proxy_settings = ProxySettings(notebook, self.settings_manager)
            proxy_frame = proxy_settings.get_frame()
            notebook.add(proxy_frame, text="代理设置")
            self.settings_panels["proxy"] = proxy_settings
        except Exception as e:
            logger.error(f"创建代理设置面板失败: {str(e)}")
            # 创建错误提示页面
            error_frame = ttk.Frame(notebook)
            ttk.Label(error_frame, text=f"加载代理设置面板失败: {str(e)}").pack(padx=20, pady=20)
            notebook.add(error_frame, text="代理设置")
    
    def _create_network_tab(self, notebook):
        """创建网络测试选项卡"""
        try:
            from test_net.network_test import NetworkTest
            
            # 创建网络测试框架
            network_frame = ttk.Frame(notebook)
            
            # 创建网络测试实例
            network_test = NetworkTest(network_frame)
            
            # 添加测试按钮
            button_frame = ttk.Frame(network_frame, padding=10)
            button_frame.pack(fill=tk.X)
            
            ttk.Button(
                button_frame, 
                text="打开网络测试工具", 
                command=network_test.create_test_window
            ).pack(padx=5, pady=5)
            
            ttk.Label(
                network_frame, 
                text="网络测试工具可以帮助您检测网络连接状态、测试下载速度，以及执行Ping操作。",
                wraplength=600
            ).pack(padx=20, pady=10)
            
            notebook.add(network_frame, text="网络测试")
            self.settings_panels["network"] = network_test
        except Exception as e:
            logger.error(f"创建网络测试面板失败: {str(e)}")
            # 创建错误提示页面
            error_frame = ttk.Frame(notebook)
            ttk.Label(error_frame, text=f"加载网络测试面板失败: {str(e)}").pack(padx=20, pady=20)
            notebook.add(error_frame, text="网络测试")
    
    def _create_buttons(self, parent):
        """创建底部按钮"""
        button_frame = ttk.Frame(parent)
        button_frame.pack(fill=tk.X, padx=5, pady=10)
        
        # 保存按钮
        save_button = ttk.Button(button_frame, text="保存设置", command=self.save_settings)
        save_button.pack(side=tk.RIGHT, padx=5)
        
        # 取消按钮
        cancel_button = ttk.Button(button_frame, text="取消", command=self.window.destroy)
        cancel_button.pack(side=tk.RIGHT, padx=5)
    
    def save_settings(self):
        """保存所有设置"""
        try:
            # 保存各面板设置
            for panel_name, panel in self.settings_panels.items():
                if hasattr(panel, "save_settings"):
                    try:
                        panel.save_settings()
                    except Exception as e:
                        logger.error(f"保存{panel_name}设置失败: {str(e)}")
                        messagebox.showerror("保存失败", f"保存{panel_name}设置失败: {str(e)}")
                        return
            
            # 保存设置文件
            self.settings_manager.save_settings()
            
            # 提示保存成功
            messagebox.showinfo("成功", "设置已保存")
            
            # 关闭窗口
            self.window.destroy()
        except Exception as e:
            logger.error(f"保存设置失败: {str(e)}")
            messagebox.showerror("保存失败", f"保存设置失败: {str(e)}")

# 打开设置窗口的函数
def open_settings_window(parent, settings_manager, theme_manager=None):
    """
    打开设置窗口
    
    Args:
        parent: 父窗口
        settings_manager: 设置管理器实例
        theme_manager: 主题管理器实例
    """
    try:
        settings_window = SettingsWindow(parent, settings_manager, theme_manager)
        return settings_window
    except Exception as e:
        logger.error(f"打开设置窗口失败: {str(e)}")
        messagebox.showerror("错误", f"打开设置窗口失败: {str(e)}")
        return None 